{
  "name": "iflow-for-obsidian",
  "version": "0.7.3",
  "description": "iFlow CLI integration for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "iflow",
    "ai",
    "assistant",
    "chat"
  ],
  "author": "junjie-yan",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {}
}
